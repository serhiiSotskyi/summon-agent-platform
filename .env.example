# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Database
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<SUPABASE_PASSWORD>@<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:<SUPABASE_PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres
CONNECTOR_ENCRYPTION_KEY=

# Queue
# Optional. Defaults to DATABASE_URL. Use this only if the worker should connect
# to a separate Postgres URL for pg-boss jobs.
PG_BOSS_DATABASE_URL=
# Legacy Redis variables are no longer used by the agent-run worker.
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google OAuth and APIs
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/connectors/google/callback
# Required once for Google Ads API reporting. User customer accounts are auto-detected after OAuth when possible.
GOOGLE_ADS_DEVELOPER_TOKEN=
# Optional overrides. Leave blank to auto-detect from the authorized Google account where supported.
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_API_VERSION=v22
GA4_PROPERTY_ID=
GOOGLE_DRIVE_QUERY=
GOOGLE_DRIVE_FOLDER_ID=

# Notion OAuth
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
NOTION_OAUTH_REDIRECT_URI=http://localhost:3000/api/connectors/notion/callback
NOTION_SEARCH_QUERY=

# LLM providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Default model settings
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4.1

# Delivery / connectors
APP_URL=http://localhost:3000
RESEND_API_KEY=
INVITE_FROM_EMAIL=
NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=
